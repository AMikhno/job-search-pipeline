# Copy to .env and fill in. .env is gitignored and must never be committed.
# V1 ingestion sources (Greenhouse/Lever) need NO credentials — they are public.

# dbt target: "dev" (DuckDB, default) or "prod" (BigQuery)
PIPELINE_TARGET=dev

# DuckDB (dev) path
DUCKDB_PATH=./data/jobs.duckdb

# BigQuery (prod). In CI these come from GitHub Actions, NOT this file.
GCP_PROJECT=your-gcp-project
BQ_DATASET=jobs
BQ_LOCATION=northamerica-northeast2

# Delivery / ops (placeholders; real values live in your keychain or GH Secrets)
HTTP_USER_AGENT=job-search-pipeline/0.1 (+https://github.com/you/job-search-pipeline)

# Email digest (deliver/digest.py). Leave SMTP_* unset to disable the digest.
# For Gmail use an app password (https://myaccount.google.com/apppasswords).
SMTP_USER=
SMTP_PASSWORD=
DIGEST_TO=

# Private company list (gitignored). Defaults to config/companies.csv, falling back
# to config/companies.example.csv if absent. Override the path here if you like.
COMPANIES_CSV=config/companies.csv
