# Copy to ~/.dbt/profiles.yml (or set DBT_PROFILES_DIR). Never commit the real file.
# Dual-target: DuckDB for dev (free, fast, no cloud), BigQuery for prod.
job_pipeline:
  target: dev
  outputs:
    dev:
      type: duckdb
      path: ../data/jobs.duckdb
      threads: 4
    prod:
      type: bigquery
      method: oauth          # CI uses Workload Identity Federation; locally use ADC
      project: "{{ env_var('GCP_PROJECT', '') }}"
      dataset: "{{ env_var('BQ_DATASET', 'jobs') }}"
      location: "{{ env_var('BQ_LOCATION', 'northamerica-northeast2') }}"
      threads: 4
