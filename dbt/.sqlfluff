# Lives in dbt/ so the dbt templater and the profile's relative DuckDB path
# (../data/jobs.duckdb) resolve correctly — run sqlfluff from this directory.
[sqlfluff]
templater = dbt
dialect = duckdb
max_line_length = 100
# ST06: forced select-clause ordering — fights our medallion column order.
# AM04: "query produces unknown number of columns" — fires on the deliberate
#        `select *` union in int_jobs__unioned.
exclude_rules = ST06, AM04

[sqlfluff:templater:dbt]
project_dir = .
profiles_dir = .
profile = job_pipeline
target = dev

[sqlfluff:indentation]
tab_space_size = 4

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.identifiers]
extended_capitalisation_policy = lower

[sqlfluff:rules:capitalisation.functions]
extended_capitalisation_policy = lower

[sqlfluff:rules:capitalisation.literals]
capitalisation_policy = lower

# House style: table aliases are implicit (`deduped d`), column aliases explicit (`… as x`).
[sqlfluff:rules:aliasing.table]
aliasing = implicit
